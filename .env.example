# LLM backend configuration for Streamlit UI
# Detection order: Ollama -> OpenAI -> AWS Bedrock
# Copy this file to .env and fill in your values
# .env is gitignored and should NOT be committed

# ============================================================================
# Ollama Configuration (Local or Network)
# ============================================================================
# Leave empty or comment out if not using Ollama
# OLLAMA_HOST: Base URL of your Ollama server (e.g., http://localhost:11434)
# OLLAMA_MODEL: Model tag to use (e.g., gemma4:e4b, llama3:8b)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# ============================================================================
# OpenAI Configuration (Fallback if Ollama unavailable)
# ============================================================================
# Leave empty if not using OpenAI
# OPENAI_API_KEY: Your OpenAI API key (starts with sk-)
# OPENAI_MODEL: Model to use (e.g., gpt-4o, gpt-4-turbo)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ============================================================================
# AWS Bedrock Configuration (Last resort fallback)
# ============================================================================
# Leave empty if not using AWS Bedrock
# AWS_PROFILE: AWS SSO profile name (e.g., AWSAdministratorAccess-051570254217)
# AWS_REGION: AWS region where Bedrock is available (e.g., us-east-1, us-west-2)
# BEDROCK_MODEL_ID: Bedrock model inference profile ID
#   Options:
#   - global.anthropic.claude-sonnet-4-6 (recommended, faster)
#   - global.anthropic.claude-opus-4-6-v1 (more powerful)
#   - global.anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_PROFILE=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# ============================================================================
# Notes
# ============================================================================
# - CLI (python -m datagen generate) uses only AWS Bedrock config
# - Streamlit UI (streamlit run app.py) auto-detects and uses the first available backend
# - For network Ollama: ensure host machine runs with OLLAMA_HOST=0.0.0.0:11434
# - Keep this file secure; do not commit .env to git
